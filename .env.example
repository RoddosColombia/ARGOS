# ─── Copia a .env y ajusta valores locales. NUNCA commitear .env. ───

# Entorno
ARGOS_ENV=dev                         # dev | staging | prod
ARGOS_LOG_LEVEL=INFO
ARGOS_VERSION=0.1.0

# JWT
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-every-env-use-a-64-char-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60

# MongoDB Atlas
# Formato: mongodb+srv://<user>:<password-url-encoded>@<cluster>.mongodb.net/<db>?...
# Password con caracteres especiales debe ir URL-encoded (! → %21, @ → %40, etc.)
MONGODB_URI=mongodb+srv://USER:PASSWORD_URL_ENCODED@CLUSTER.mongodb.net/argos?retryWrites=true&w=majority
MONGODB_DATABASE=argos
MONGODB_TEST_DATABASE=argos_test

# Admin bootstrap (seed lo persiste en users collection en primera corrida de Build 0.3+)
# Generar hash con: python -c "import bcrypt; print(bcrypt.hashpw(b'tu-password', bcrypt.gensalt()).decode())"
ADMIN_EMAIL=ceo@roddos.com
ADMIN_PASSWORD_HASH=$2b$12$REEMPLAZAR_CON_HASH_REAL_GENERADO_LOCALMENTE
ADMIN_ROLE=ceo
ADMIN_WORKSPACE_ID=RODDOS

# CGO bootstrap (Build 2.5.5 · ROG-G1 · Iván Echeverri)
# Mismo workspace que CEO. Si las env vars están vacías, el seed del CGO se salta.
# Generar hash con el mismo comando bcrypt de arriba con el password de Iván.
CGO_EMAIL=ivan@roddos.com
CGO_PASSWORD_HASH=$2b$12$REEMPLAZAR_CON_HASH_REAL_GENERADO_LOCALMENTE
CGO_WORKSPACE_ID=RODDOS

# Anthropic (Build 1.1+ · Haiku para Scout classifier)
# Sin la key, el classifier degrada a NoOpClassifier (descarta todo · catálogo no se contamina)
ANTHROPIC_API_KEY=

# Apify (Build 1.1+ · FB Marketplace via apify/facebook-marketplace-scraper)
# Sin el token, el cliente queda deshabilitado y Scout solo pega contra MELI
APIFY_API_TOKEN=

# SerpAPI (Build 1.3+ · Google Trends para Trends agent)
# Sin la key, TrendsAgent skip silencioso · job trends_refresh no genera datos
SERPAPI_API_KEY=

# TikHub.io (Build 2.3+ · social listening IG/TikTok para Social agent)
# Sin la key, SocialAgent skip silencioso · job social_refresh no genera datos
TIKHUB_API_KEY=

# OpenAI (Build 3.2+ · text-embedding-3-small para MemoryAgent embeddings · 1536 dim)
# Sin la key, embed jobs skip silencioso y search retorna lista vacía
OPENAI_API_KEY=

# Voyage AI (Build 3.2+ · alternativa a OpenAI · voyage-3 dim 1024 · pendiente DT)
# Build 3.2 SOLO usa OpenAI · Voyage queda como stub para futuro multi-provider
VOYAGE_API_KEY=

# Qdrant self-hosted en Render (Build 3.2+ · vector DB para GraphRAG)
# Formato: https://qdrant-instance.onrender.com (sin trailing slash)
# Sin la URL, MemoryAgent skip silencioso (jobs no embedean · search retorna [])
QDRANT_URL=
QDRANT_API_KEY=

# Twilio WhatsApp (Build market-intelligence-complete · briefing + alertas precio)
# Sin TWILIO_ACCOUNT_SID/_AUTH_TOKEN/_WHATSAPP_FROM, NotificationsAgent skip silencioso.
# TWILIO_WHATSAPP_FROM y _TO usan formato `whatsapp:+57XXXXXXXXXX` (sandbox o productivo).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# Score Engine externo (Phase 2 · repo independiente de Iván)
# ARGOS NO ejecuta scores · solo lee resultados desde MongoDB compartido (RODDOS-web)
# y expone un cliente para que WhatsApp Agent dispare evaluaciones.
# RODDOS_MONGODB_URI: connection string al cluster Atlas de RODDOS-web · DB roddos_comercial
#   contiene la colección scoring_solicitudes que escribe el Score Engine de Iván.
#   Sin URI → ScoreReader.get_recent() devuelve [] (skip silencioso).
# SCORE_ENGINE_API_URL: endpoint HTTP del repo de Iván para POST /v1/evaluate.
#   Sin URL → ScoreEngineClient.evaluate() devuelve mock con decision="no_configurado".
RODDOS_MONGODB_URI=
RODDOS_MONGODB_DATABASE=roddos_comercial
SCORE_ENGINE_API_URL=
SCORE_ENGINE_API_KEY=

# SISMO V2 (Build 4.1+ · ERP de RODDOS · lectura read-only de inventario y ventas)
# Sin URL+KEY, SismoAgent skip silencioso (sync job no toca Mongo · /sismo/inventory devuelve []).
# La key debe ser SCOPE READ-ONLY · ROG-A11 (aislamiento de credenciales).
SISMO_API_URL=
SISMO_API_KEY=

# CORS (ajustar cuando Build 0.4 levante el frontend)
ARGOS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
